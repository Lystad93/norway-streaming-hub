# apps/norway-streaming-hub/.env  — APP-LEVEL secrets, pulled in via `env_file: - .env`.
# Copy to .env (it's gitignored). All values optional.

# --- TMDB fallback (optional but recommended) ---
# Used only if JustWatch is down/empty. Set EITHER one:
#   TMDB_API_TOKEN — v4 read access token (preferred, sent as Bearer), OR
#   TMDB_API_KEY   — v3 api key
# Get them at https://www.themoviedb.org/settings/api
TMDB_API_TOKEN=
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# NOT here — these belong in your ROOT /opt/docker/.env (shared stack config):
#   STREAMINGHUB_HOSTNAME=streaminghub.${DOMAIN}
#   DOCKER_DATA_DIR is already defined there (default /opt/docker/data)
# And add `streaminghub` to COMPOSE_PROFILES, plus the include line in
# /opt/docker/compose.yaml — see README "Deploying into the VPS stack".
# -----------------------------------------------------------------------------
